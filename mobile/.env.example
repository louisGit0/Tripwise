# URL du backend NestJS (sans slash final)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Token Mapbox public (runtime — visible dans le bundle JS)
# Restreindre aux domaines/apps autorisés dans le dashboard Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# Token secret Mapbox (build-time uniquement — NE PAS préfixer EXPO_PUBLIC_)
# Requis pour EAS Build / expo prebuild avec @rnmapbox/maps
# Crée un token secret avec le scope DOWNLOADS:READ sur account.mapbox.com
MAPBOX_DOWNLOAD_TOKEN=sk.your_secret_download_token_here

# Google OAuth (optionnel — pour expo-auth-session)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id
