# ── Application ───────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database ───────────────────────────────────────────────────────────────────
# Option A — variables individuelles (Docker Compose local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=tripwise
DB_PASSWORD=tripwise
DB_NAME=tripwise
# Option B — connection string complète (prend la priorité sur les variables ci-dessus)
# Utiliser en production : Supabase, Neon, Render Postgres…
# DATABASE_URL=postgresql://user:password@db.xxx.supabase.co:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Obtenir un token sur https://account.mapbox.com → "Access tokens"
# Quota indicatif plan gratuit : ~100 000 req/mois Geocoding et Directions
# (à vérifier dans le dashboard Mapbox, les limites peuvent évoluer)
MAPBOX_TOKEN=pk.eyJ1IjoiXXXXX...
# Alias legacy conservé pour compatibilité (préférer MAPBOX_TOKEN)
MAPBOX_ACCESS_TOKEN=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Contenu du fichier .p8 sur une ligne (remplacer les sauts de ligne par \n)
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/apple/callback

# ── CORS & Frontend ───────────────────────────────────────────────────────────
# Liste séparée par virgules des origines autorisées.
# En dev :  CORS_ORIGINS=http://localhost:3001
# En prod : CORS_ORIGINS=https://tripwise-black.vercel.app
CORS_ORIGINS=http://localhost:3001
# URL du frontend — utilisée pour les redirections OAuth
# En dev :  FRONTEND_URL=http://localhost:3001
# En prod : FRONTEND_URL=https://tripwise-black.vercel.app
FRONTEND_URL=http://localhost:3001

# ── Fuel prices API (prix-carburants.gouv.fr) ─────────────────────────────────
# No API key needed — public dataset
FUEL_PRICES_API_URL=https://data.prix-carburants.gouv.fr/rbx_olap

# ── IRVE — charging stations (data.gouv.fr) ───────────────────────────────────
# No API key needed — public dataset
IRVE_API_URL=https://www.data.gouv.fr/fr/datasets/r/8d9398ae-3037-48b2-be19-412c24561fbb

# ── TollGuru — calcul de péages ────────────────────────────────────────────────
# Obtenir une clé sur https://tollguru.com → Dashboard → API Keys
# Plan gratuit : 500 req/mois. Laisser vide pour désactiver le calcul de péages.
TOLLGURU_API_KEY=
