# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=tripwise
DB_PASSWORD=tripwise
DB_NAME=tripwise
# Alternatively, use a full connection string (takes precedence if set):
# DATABASE_URL=postgresql://tripwise:tripwise@localhost:5432/tripwise

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Obtenir un token sur https://account.mapbox.com → "Access tokens"
# Quota indicatif plan gratuit : ~100 000 req/mois Geocoding et Directions
# (à vérifier dans le dashboard Mapbox, les limites peuvent évoluer)
MAPBOX_TOKEN=pk.eyJ1IjoiXXXXX...
# Alias legacy conservé pour compatibilité (préférer MAPBOX_TOKEN)
MAPBOX_ACCESS_TOKEN=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# Path to the .p8 private key file (or paste the content as a single-line string)
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/apple/callback

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# ── Fuel prices API (prix-carburants.gouv.fr) ─────────────────────────────────
# No API key needed — public dataset
FUEL_PRICES_API_URL=https://data.prix-carburants.gouv.fr/rbx_olap

# ── IRVE — charging stations (data.gouv.fr) ───────────────────────────────────
# No API key needed — public dataset
IRVE_API_URL=https://www.data.gouv.fr/fr/datasets/r/8d9398ae-3037-48b2-be19-412c24561fbb
