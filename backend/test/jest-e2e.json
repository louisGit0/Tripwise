{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@verygoodtrip/shared$": "<rootDir>/../shared/src/index.ts",
    "^@verygoodtrip/shared/(.*)$": "<rootDir>/../shared/src/$1"
  }
}
